# ================================================================
# School ERP SaaS - Environment Variables
# Copy this file to .env and fill in the values
# ================================================================

# ── Application ─────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME="School ERP"
# Comma-separated extra origins allowed for CORS (e.g. your Vercel URL)
ALLOWED_ORIGINS=

# ── PostgreSQL Database ─────────────────────────────────────────
POSTGRES_USER=school_erp
POSTGRES_PASSWORD=your_strong_db_password_here
POSTGRES_DB=school_erp
DATABASE_URL=postgresql://school_erp:your_strong_db_password_here@localhost:5433/school_erp
# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_URL=redis://:your_strong_redis_password_here@localhost:6379

# ── JWT (RS256 Key Pair) ─────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the content (keep newlines as \n):
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MinIO / S3 Storage ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_strong_minio_password_here
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=your_strong_minio_password_here
S3_BUCKET=school-erp
S3_REGION=us-east-1
# For AWS S3 (production):
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="School ERP <noreply@school-erp.com>"
# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASS=SG.your_api_key_here

# ── SMS (MSG91) ──────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER=SCHERP
MSG91_TEMPLATE_ID=your_template_id_here

# ── WhatsApp (360dialog / Twilio) ───────────────────────────────
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_TOKEN=your_whatsapp_token_here

# ── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=300

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=debug
# Options: error, warn, info, http, verbose, debug, silly



